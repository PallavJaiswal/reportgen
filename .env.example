# Local development (this machine only) — copy to .env.local and fill in.
# .env.local is gitignored; never commit real keys.
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Production (Vercel) — set these in the Vercel project's environment
# variables UI, not in this file.
# AI_PROVIDER=groq
# GROQ_API_KEY=gsk_...
# KV_REST_API_URL=...
# KV_REST_API_TOKEN=...
# DEMO_MODE=true
# RATE_LIMIT_PER_USER=1
